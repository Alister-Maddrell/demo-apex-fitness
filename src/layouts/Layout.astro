---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
const metaDescription = description || "Sydney CBD's top-rated gym on Elizabeth Street. HIIT, boxing, strength, yoga & Olympic lifting with expert coaches. First week free — no commitment. Book now.";

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/classes', label: 'Classes' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={metaDescription} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://apexperformance.com.au${currentPath}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_AU" />
  <title>{title}</title>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "SportsActivityLocation"],
    "name": "Apex Performance Studio",
    "description": "Premium gym and fitness studio in Sydney CBD offering HIIT, boxing, strength training, yoga, Olympic lifting and personal training with expert coaches.",
    "url": "https://apexperformance.com.au",
    "telephone": "+61431555290",
    "email": "info@apexperformance.com.au",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "115 Elizabeth Street",
      "addressLocality": "Sydney",
      "addressRegion": "NSW",
      "postalCode": "2000",
      "addressCountry": "AU"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -33.8719,
      "longitude": 151.2093
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "05:00",
        "closes": "21:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "06:00",
        "closes": "17:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Sunday",
        "opens": "07:00",
        "closes": "14:00"
      }
    ],
    "priceRange": "$30–$149",
    "currenciesAccepted": "AUD",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "500",
      "bestRating": "5"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Fitness Classes & Memberships",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "HIIT Training" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Strength & Conditioning" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Boxing" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Yoga & Mobility" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Personal Training" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Olympic Lifting" } }
      ]
    },
    "image": "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920&h=1080&fit=crop&q=80",
    "sameAs": ["https://instagram.com/apexperformancesydney"]
  })} />
</head>
<body class="bg-bg-primary text-text-body">

  <!-- Navigation -->
  <nav id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 bg-transparent" style="will-change: transform, background-color;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-20 lg:h-24 transition-all duration-500">
      <!-- Logo -->
      <a href="/" class="font-heading text-2xl lg:text-3xl text-text-primary tracking-wider uppercase relative z-60 group">
        <span class="text-gradient-warm">APEX</span> <span class="text-text-secondary group-hover:text-text-primary transition-colors duration-300">PERFORMANCE</span>
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden md:flex items-center gap-10">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`font-display text-[0.75rem] uppercase tracking-[0.18em] font-semibold transition-all duration-300 hover:text-accent-orange relative ${
              currentPath === link.href || currentPath === link.href + '/' ? 'text-accent-orange' : 'text-text-secondary'
            }`}
          >
            {link.label}
            {(currentPath === link.href || currentPath === link.href + '/') && (
              <span class="absolute -bottom-1 left-0 w-full h-0.5 bg-gradient-to-r from-accent-orange to-transparent rounded-full"></span>
            )}
          </a>
        ))}
      </div>

      <!-- CTA Button (desktop) -->
      <a href="/contact" class="hidden md:inline-flex btn-primary !py-3 !px-7 !text-xs">
        Start Your Free Week
      </a>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="md:hidden relative z-60 w-10 h-10 flex items-center justify-center" aria-label="Toggle menu">
        <div id="hamburger-lines" class="w-6 flex flex-col gap-[5px] transition-all duration-300">
          <span class="block h-[2px] w-full bg-text-primary transition-all duration-300 origin-center"></span>
          <span class="block h-[2px] w-full bg-text-primary transition-all duration-300"></span>
          <span class="block h-[2px] w-full bg-text-primary transition-all duration-300 origin-center"></span>
        </div>
      </button>
    </div>

    <!-- Mobile Menu (full-screen overlay) -->
    <div id="mobile-menu" class="fixed inset-0 bg-bg-primary/98 backdrop-blur-xl z-50 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-400 md:hidden">
      <!-- Decorative background for mobile menu -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-1/4 right-10 w-64 h-64 rounded-full bg-accent-orange/3 blur-3xl"></div>
        <div class="absolute bottom-1/3 left-10 w-48 h-48 rounded-full bg-accent-lime/2 blur-3xl"></div>
      </div>
      <div class="relative flex flex-col items-center gap-8">
        {navLinks.map((link, i) => (
          <a
            href={link.href}
            class={`font-heading text-5xl uppercase tracking-wider transition-all duration-300 hover:text-accent-orange mobile-nav-link opacity-0 translate-y-4`}
            style={`transition-delay: ${100 + i * 80}ms;`}
          >
            {currentPath === link.href || currentPath === link.href + '/' ? (
              <span class="text-gradient-warm">{link.label}</span>
            ) : (
              <span class="text-text-primary">{link.label}</span>
            )}
          </a>
        ))}
        <a href="/contact" class="btn-primary mt-6 mobile-nav-link opacity-0 translate-y-4" style="transition-delay: 340ms;">
          Start Your Free Week
        </a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="relative bg-bg-footer pt-24 pb-8 border-t border-white/5 overflow-hidden">
    <!-- Ambient glow -->
    <div class="absolute top-0 left-1/4 w-96 h-48 bg-accent-orange/3 blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <!-- Footer top: Logo + tagline -->
      <div class="mb-16">
        <a href="/" class="font-heading text-3xl text-text-primary tracking-wider uppercase">
          <span class="text-gradient-warm">APEX</span> PERFORMANCE
        </a>
        <p class="text-text-muted text-sm mt-3 max-w-sm leading-relaxed">Helping Sydney transform since 2014. Expert coaching, proven results, and a community that keeps you coming back. 115 Elizabeth Street, near St James Station.</p>
        <div class="w-16 h-px bg-gradient-to-r from-accent-orange/40 to-transparent mt-6"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-16">
        <!-- Quick Links -->
        <div>
          <h4 class="font-display text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary mb-6">Quick Links</h4>
          <ul class="space-y-3.5 font-body text-sm">
            <li><a href="/" class="text-text-muted hover:text-accent-orange transition-all duration-300 hover:translate-x-1 inline-block">Home</a></li>
            <li><a href="/classes" class="text-text-muted hover:text-accent-orange transition-all duration-300 hover:translate-x-1 inline-block">Gym Classes & Coaching</a></li>
            <li><a href="/contact" class="text-text-muted hover:text-accent-orange transition-all duration-300 hover:translate-x-1 inline-block">Contact</a></li>
            <li><a href="/contact" class="text-text-muted hover:text-accent-orange transition-all duration-300 hover:translate-x-1 inline-block">Start Your Free Week</a></li>
          </ul>
        </div>

        <!-- Class Schedule -->
        <div>
          <h4 class="font-display text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary mb-6">Class Schedule</h4>
          <ul class="space-y-3.5 font-body text-sm">
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-accent-orange/60"></span>HIIT — Daily 6am & 12pm</li>
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-red-500/60"></span>Boxing — Mon/Wed/Fri</li>
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-500/60"></span>Strength — Daily</li>
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-accent-lime/60"></span>Yoga — Mon/Wed/Fri/Sat/Sun</li>
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-purple-500/60"></span>Olympic Lifting — Tue/Thu/Sat</li>
          </ul>
        </div>

        <!-- Contact Info -->
        <div>
          <h4 class="font-display text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary mb-6">Contact Info</h4>
          <ul class="space-y-3.5 font-body text-sm">
            <li class="text-text-muted">115 Elizabeth Street, Sydney NSW 2000</li>
            <li><a href="tel:0431555290" class="text-text-muted hover:text-accent-orange transition-colors duration-300">0431 555 290</a></li>
            <li><a href="mailto:info@apexperformance.com.au" class="text-text-muted hover:text-accent-orange transition-colors duration-300">info@apexperformance.com.au</a></li>
            <li class="text-text-muted">Mon–Fri 5am–9pm</li>
            <li class="text-text-muted">Sat 6am–5pm · Sun 7am–2pm</li>
          </ul>
        </div>

        <!-- Social & Newsletter -->
        <div>
          <h4 class="font-display text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary mb-6">Stay Connected</h4>
          <p class="text-sm text-text-muted mb-3">Follow us <a href="https://instagram.com/apexperformancesydney" target="_blank" rel="noopener" class="text-accent-orange hover:underline">@apexperformancesydney</a></p>
          <p class="text-sm text-text-muted mb-5">Weekly training tips, member spotlights & exclusive deals:</p>
          <form class="flex gap-2" onsubmit="event.preventDefault();">
            <input type="email" placeholder="Your email" class="bg-white/[0.04] border border-white/8 rounded-xl px-4 py-3 text-sm text-white placeholder-text-muted flex-1 focus:outline-none focus:border-accent-orange/60 focus:ring-1 focus:ring-accent-orange/20 transition-all duration-300 backdrop-blur-sm" />
            <button type="submit" class="bg-gradient-to-r from-accent-orange to-[#E85A1E] text-white font-display font-bold text-xs uppercase tracking-wider px-5 py-3 rounded-xl hover:brightness-110 transition-all duration-300 hover:shadow-lg hover:shadow-accent-orange/20">Join</button>
          </form>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="hr-gradient mb-8"></div>
      <div class="flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-text-muted">
        <p>&copy; 2014–2026 Apex Performance Studio. All rights reserved.</p>
        <p class="font-display tracking-wider">ABN: 55 123 987 654</p>
      </div>
    </div>
  </footer>

  <!-- Scripts -->
  <script>
    // ── Nav scroll effect ──
    const navbar = document.getElementById('navbar');
    const navInner = navbar?.querySelector(':scope > div') as HTMLElement;

    const updateNav = () => {
      if (!navbar || !navInner) return;
      if (window.scrollY > 60) {
        navbar.classList.add('shadow-lg', 'shadow-black/20');
        navbar.classList.remove('bg-transparent');
        navbar.style.backgroundColor = 'rgba(11, 11, 15, 0.92)';
        navbar.style.backdropFilter = 'blur(16px)';
        navbar.style.webkitBackdropFilter = 'blur(16px)';
        navbar.style.borderBottom = '1px solid rgba(255,255,255,0.04)';
        navInner.style.height = '64px';
      } else {
        navbar.classList.remove('shadow-lg', 'shadow-black/20');
        navbar.classList.add('bg-transparent');
        navbar.style.backgroundColor = '';
        navbar.style.backdropFilter = '';
        navbar.style.webkitBackdropFilter = '';
        navbar.style.borderBottom = '';
        navInner.style.height = '';
      }
    };
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    // ── Mobile menu toggle ──
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerLines = document.getElementById('hamburger-lines');
    let menuOpen = false;

    mobileMenuBtn?.addEventListener('click', () => {
      menuOpen = !menuOpen;
      if (!mobileMenu || !hamburgerLines) return;

      const spans = hamburgerLines.querySelectorAll('span');

      if (menuOpen) {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';

        if (spans[0]) { spans[0].style.transform = 'translateY(7px) rotate(45deg)'; }
        if (spans[1]) { spans[1].style.opacity = '0'; }
        if (spans[2]) { spans[2].style.transform = 'translateY(-7px) rotate(-45deg)'; }

        mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
          link.classList.remove('opacity-0', 'translate-y-4');
          link.classList.add('opacity-100', 'translate-y-0');
        });
      } else {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = '';

        spans.forEach(s => { s.style.transform = ''; s.style.opacity = ''; });

        mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
          link.classList.add('opacity-0', 'translate-y-4');
          link.classList.remove('opacity-100', 'translate-y-0');
        });
      }
    });

    mobileMenu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        if (menuOpen) mobileMenuBtn?.click();
      });
    });

    // ── Scroll-triggered reveal animations ──
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
    );

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // ── Animated counter ──
    const counterObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.count || '0');
          const suffix = el.dataset.suffix || '';
          const duration = 2000;
          const start = performance.now();

          const animate = (now: number) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.floor(target * eased) + suffix;
            if (progress < 1) requestAnimationFrame(animate);
          };

          requestAnimationFrame(animate);
          counterObserver.unobserve(el);
        });
      },
      { threshold: 0.3 }
    );

    document.querySelectorAll('[data-count]').forEach(el => counterObserver.observe(el));
  </script>
</body>
</html>
