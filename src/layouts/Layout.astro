---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
const metaDescription = description || "Sydney CBD's top-rated gym on Elizabeth Street. HIIT, boxing, strength, yoga & Olympic lifting with expert coaches. First week free — no commitment. Book now.";

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/classes', label: 'Classes' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={metaDescription} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://apexperformance.com.au${currentPath}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_AU" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={metaDescription} />
  <title>{title}</title>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "SportsActivityLocation"],
    "name": "Apex Performance Studio",
    "description": "Premium gym and fitness studio in Sydney CBD offering HIIT, boxing, strength training, yoga, Olympic lifting and personal training with expert coaches.",
    "url": "https://apexperformance.com.au",
    "telephone": "+61431555290",
    "email": "info@apexperformance.com.au",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "115 Elizabeth Street",
      "addressLocality": "Sydney",
      "addressRegion": "NSW",
      "postalCode": "2000",
      "addressCountry": "AU"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -33.8719,
      "longitude": 151.2093
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "05:00",
        "closes": "21:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "06:00",
        "closes": "17:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Sunday",
        "opens": "07:00",
        "closes": "14:00"
      }
    ],
    "priceRange": "$30–$149",
    "currenciesAccepted": "AUD",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "500",
      "bestRating": "5"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Fitness Classes & Memberships",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "HIIT Training" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Strength & Conditioning" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Boxing" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Yoga & Mobility" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Personal Training" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Olympic Lifting" } }
      ]
    },
    "image": "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920&h=1080&fit=crop&q=80",
    "sameAs": ["https://instagram.com/apexperformancesydney"]
  })} />
  <style is:global>
    /* Mobile menu fixes — outside Tailwind layers to override utilities */
    @media (max-width: 767px) {
      #mobile-menu {
        background-color: #050505 !important;
        z-index: 999 !important;
        justify-content: flex-start !important;
        padding-top: 90px !important;
        overflow-y: auto !important;
      }

      #mobile-menu .mobile-nav-link {
        font-size: 2.5rem !important;
      }

      #mobile-menu .btn-primary {
        font-size: 0.75rem !important;
        padding: 14px 28px !important;
        display: inline-flex !important;
      }

      #mobile-menu-btn {
        z-index: 1001 !important;
      }

      /* Nav always has dark background, z-index high enough for menu to cover hero */
      #navbar {
        background-color: rgba(5, 5, 5, 0.9) !important;
        backdrop-filter: blur(10px) !important;
        -webkit-backdrop-filter: blur(10px) !important;
        z-index: 999 !important;
      }

      #hamburger-lines span {
        background-color: #fff !important;
      }

      /* Hide header CTA */
      #navbar > div > a.btn-primary {
        display: none !important;
      }

      html, body {
        overflow-x: hidden;
      }

      /* Hero banner below nav */
      .hero-banner {
        margin-top: 56px !important;
      }
    }
  </style>
</head>
<body class="bg-bg-primary text-text-body">

  <!-- Skip to content -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-accent-orange focus:text-black focus:px-4 focus:py-2 focus:text-sm focus:font-display focus:font-700">Skip to main content</a>

  <!-- Navigation — Hard, minimal -->
  <nav id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-400 bg-transparent" style="will-change: background-color;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-20 lg:h-24 transition-all duration-400">
      <!-- Logo -->
      <a href="/" class="font-heading text-2xl lg:text-3xl text-text-primary tracking-wider uppercase relative z-60 group">
        <span class="text-accent-orange">APEX</span><span class="text-text-muted group-hover:text-text-primary transition-colors duration-300 ml-1">PERFORMANCE</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-12">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`font-display text-[0.7rem] uppercase tracking-[0.2em] font-700 transition-all duration-300 hover:text-accent-orange relative ${
              currentPath === link.href || currentPath === link.href + '/' ? 'text-accent-orange' : 'text-text-muted'
            }`}
          >
            {link.label}
            {(currentPath === link.href || currentPath === link.href + '/') && (
              <span class="absolute -bottom-1 left-0 w-full h-[2px] bg-accent-orange"></span>
            )}
          </a>
        ))}
      </div>

      <!-- CTA (desktop) -->
      <a href="/contact" class="hidden md:inline-flex btn-primary !py-3 !px-7 !text-[0.65rem]">
        Start Your Free Week
      </a>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="md:hidden relative z-60 w-10 h-10 flex items-center justify-center" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <div id="hamburger-lines" class="w-6 flex flex-col gap-[6px] transition-all duration-300">
          <span class="block h-[2px] w-full bg-text-primary transition-all duration-300 origin-center"></span>
          <span class="block h-[2px] w-full bg-text-primary transition-all duration-300"></span>
          <span class="block h-[2px] w-full bg-text-primary transition-all duration-300 origin-center"></span>
        </div>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="fixed inset-0 bg-bg-primary z-50 flex flex-col items-start justify-center opacity-0 pointer-events-none transition-opacity duration-300 md:hidden px-10">
      <div class="flex flex-col gap-6">
        {navLinks.map((link, i) => (
          <a
            href={link.href}
            class={`font-heading text-5xl uppercase tracking-wider transition-all duration-300 hover:text-accent-orange mobile-nav-link opacity-0 translate-x-[-20px]`}
            style={`transition-delay: ${100 + i * 80}ms;`}
          >
            {currentPath === link.href || currentPath === link.href + '/' ? (
              <span class="text-accent-orange">{link.label}</span>
            ) : (
              <span class="text-text-primary">{link.label}</span>
            )}
          </a>
        ))}
        <div class="w-12 h-[2px] bg-accent-orange mt-4 mobile-nav-link opacity-0 translate-x-[-20px]" style="transition-delay: 340ms;"></div>
        <a href="/contact" class="btn-primary mt-2 mobile-nav-link opacity-0 translate-x-[-20px]" style="transition-delay: 420ms;">
          Start Your Free Week
        </a>
      </div>
    </div>
  </nav>

  <main id="main-content">
    <slot />
  </main>

  <!-- Footer — Clean, structured -->
  <footer class="relative bg-bg-footer pt-20 pb-8 border-t border-white/5 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <!-- Footer top -->
      <div class="mb-14">
        <a href="/" class="font-heading text-3xl text-text-primary tracking-wider uppercase">
          <span class="text-accent-orange">APEX</span> PERFORMANCE
        </a>
        <p class="text-text-muted text-sm mt-3 max-w-sm leading-relaxed">Helping Sydney transform since 2014. Expert coaching, proven results, and a community that keeps you coming back. 115 Elizabeth Street, near St James Station.</p>
        <div class="w-12 h-[2px] bg-accent-orange mt-6"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-14">
        <!-- Quick Links -->
        <div>
          <h4 class="font-display text-xs font-700 uppercase tracking-[0.2em] text-text-secondary mb-6">Quick Links</h4>
          <ul class="space-y-3.5 font-body text-sm">
            <li><a href="/" class="text-text-muted hover:text-accent-orange transition-colors duration-300">Home</a></li>
            <li><a href="/classes" class="text-text-muted hover:text-accent-orange transition-colors duration-300">Gym Classes & Coaching</a></li>
            <li><a href="/contact" class="text-text-muted hover:text-accent-orange transition-colors duration-300">Contact</a></li>
            <li><a href="/contact" class="text-text-muted hover:text-accent-orange transition-colors duration-300">Start Your Free Week</a></li>
          </ul>
        </div>

        <!-- Schedule -->
        <div>
          <h4 class="font-display text-xs font-700 uppercase tracking-[0.2em] text-text-secondary mb-6">Class Schedule</h4>
          <ul class="space-y-3.5 font-body text-sm">
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 bg-accent-orange"></span>HIIT — Daily 6am & 12pm</li>
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 bg-red-500"></span>Boxing — Mon/Wed/Fri</li>
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 bg-blue-500"></span>Strength — Daily</li>
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 bg-accent-lime"></span>Yoga — Mon/Wed/Fri/Sat/Sun</li>
            <li class="text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 bg-purple-500"></span>Olympic Lifting — Tue/Thu/Sat</li>
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <h4 class="font-display text-xs font-700 uppercase tracking-[0.2em] text-text-secondary mb-6">Contact Info</h4>
          <ul class="space-y-3.5 font-body text-sm">
            <li class="text-text-muted">115 Elizabeth Street, Sydney NSW 2000</li>
            <li><a href="tel:0431555290" class="text-text-muted hover:text-accent-orange transition-colors duration-300">0431 555 290</a></li>
            <li><a href="mailto:info@apexperformance.com.au" class="text-text-muted hover:text-accent-orange transition-colors duration-300">info@apexperformance.com.au</a></li>
            <li class="text-text-muted">Mon–Fri 5am–9pm</li>
            <li class="text-text-muted">Sat 6am–5pm · Sun 7am–2pm</li>
          </ul>
        </div>

        <!-- Newsletter -->
        <div>
          <h4 class="font-display text-xs font-700 uppercase tracking-[0.2em] text-text-secondary mb-6">Stay Connected</h4>
          <p class="text-sm text-text-muted mb-3">Follow us <a href="https://instagram.com/apexperformancesydney" target="_blank" rel="noopener" class="text-accent-orange hover:underline">@apexperformancesydney</a></p>
          <p class="text-sm text-text-muted mb-5">Weekly training tips, member spotlights & exclusive deals:</p>
          <form class="flex gap-0" onsubmit="event.preventDefault();">
            <input type="email" placeholder="Your email" aria-label="Email address for newsletter" class="bg-white/[0.04] border border-white/8 border-r-0 px-4 py-3 text-sm text-white placeholder-text-muted flex-1 focus:outline-none focus:border-accent-orange/60 transition-all duration-300" />
            <button type="submit" class="bg-accent-orange text-black font-display font-700 text-xs uppercase tracking-wider px-5 py-3 hover:bg-white transition-all duration-200">Join</button>
          </form>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="h-px bg-white/5 mb-8"></div>
      <div class="flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-text-muted">
        <p>&copy; 2014–2026 Apex Performance Studio. All rights reserved.</p>
        <p class="font-display tracking-wider">ABN: 55 123 987 654</p>
      </div>
    </div>
  </footer>

  <!-- Scripts -->
  <script>
    // ── Nav scroll ──
    const navbar = document.getElementById('navbar');
    const navInner = navbar?.querySelector(':scope > div') as HTMLElement;

    const updateNav = () => {
      if (!navbar || !navInner) return;
      if (window.scrollY > 60) {
        navbar.classList.add('shadow-lg', 'shadow-black/30');
        navbar.classList.remove('bg-transparent');
        navbar.style.backgroundColor = 'rgba(5, 5, 5, 0.92)';
        navbar.style.backdropFilter = 'blur(16px) saturate(1.2)';
        navbar.style.webkitBackdropFilter = 'blur(16px) saturate(1.2)';
        navbar.style.borderBottom = '1px solid rgba(255,90,31,0.08)';
        navInner.style.height = '64px';
      } else {
        navbar.classList.remove('shadow-lg', 'shadow-black/30');
        navbar.classList.add('bg-transparent');
        navbar.style.backgroundColor = '';
        navbar.style.backdropFilter = '';
        navbar.style.webkitBackdropFilter = '';
        navbar.style.borderBottom = '';
        navInner.style.height = '';
      }
    };
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    // ── Mobile menu ──
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerLines = document.getElementById('hamburger-lines');
    let menuOpen = false;

    // Move menu to body level so it escapes nav's stacking context
    if (mobileMenu) document.body.appendChild(mobileMenu);

    // Inject a close button inside the menu (hamburger can't escape nav stacking context)
    if (mobileMenu) {
      const closeBtn = document.createElement('button');
      closeBtn.id = 'menu-close-btn';
      closeBtn.setAttribute('aria-label', 'Close menu');
      closeBtn.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>';
      closeBtn.style.cssText = 'position:absolute;top:18px;right:18px;z-index:10;background:none;border:none;cursor:pointer;padding:8px;';
      mobileMenu.appendChild(closeBtn);
      closeBtn.addEventListener('click', () => { if (menuOpen) toggleMenu(); });
    }

    function toggleMenu() {
      menuOpen = !menuOpen;
      if (!mobileMenu || !hamburgerLines) return;

      const spans = hamburgerLines.querySelectorAll('span');
      mobileMenuBtn?.setAttribute('aria-expanded', String(menuOpen));

      if (menuOpen) {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';

        if (spans[0]) { spans[0].style.transform = 'translateY(8px) rotate(45deg)'; }
        if (spans[1]) { spans[1].style.opacity = '0'; }
        if (spans[2]) { spans[2].style.transform = 'translateY(-8px) rotate(-45deg)'; }

        mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
          link.classList.remove('opacity-0', 'translate-x-[-20px]');
          link.classList.add('opacity-100', 'translate-x-0');
        });
      } else {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = '';

        spans.forEach(s => { s.style.transform = ''; s.style.opacity = ''; });

        mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
          link.classList.add('opacity-0', 'translate-x-[-20px]');
          link.classList.remove('opacity-100', 'translate-x-0');
        });
      }
    }

    mobileMenuBtn?.addEventListener('click', toggleMenu);

    mobileMenu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        if (menuOpen) toggleMenu();
      });
    });

    // ── Scroll reveals ──
    const revealEls = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');

    if ('IntersectionObserver' in window) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.01, rootMargin: '50px 0px -10px 0px' }
      );

      revealEls.forEach(el => revealObserver.observe(el));

      // Safety net: force all reveals visible after 3 seconds
      setTimeout(() => {
        revealEls.forEach(el => el.classList.add('visible'));
      }, 3000);
    } else {
      // No IntersectionObserver support — show everything immediately
      revealEls.forEach(el => el.classList.add('visible'));
    }

    // ── Animated counters ──
    const counterObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.count || '0');
          const suffix = el.dataset.suffix || '';
          const duration = 2000;
          const start = performance.now();

          const animate = (now: number) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.floor(target * eased) + suffix;
            if (progress < 1) requestAnimationFrame(animate);
          };

          requestAnimationFrame(animate);
          counterObserver.unobserve(el);
        });
      },
      { threshold: 0.3 }
    );

    document.querySelectorAll('[data-count]').forEach(el => counterObserver.observe(el));
  </script>
  <script>
    if (new URLSearchParams(window.location.search).has('preview')) {
      document.documentElement.style.scrollBehavior = 'auto';
      document.querySelectorAll('img[loading="lazy"]').forEach(img => img.loading = 'eager');
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => el.classList.add('visible'));
      let scrolling = false, pos = 0, dir = 1, last = 0, rafId = 0;
      const pxPerSec = 150;
      function autoScroll(ts) {
        if (!scrolling) return;
        if (!last) last = ts;
        const dt = ts - last;
        last = ts;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        pos += dir * pxPerSec * (dt / 1000);
        if (pos >= max) { dir = -1; pos = max; }
        if (pos <= 0) { dir = 1; pos = 0; }
        window.scrollTo(0, pos);
        rafId = requestAnimationFrame(autoScroll);
      }
      window.addEventListener('message', (e) => {
        if (e.data === 'start-scroll') {
          if (!scrolling) { scrolling = true; last = 0; rafId = requestAnimationFrame(autoScroll); }
        } else if (e.data === 'stop-scroll') {
          scrolling = false; cancelAnimationFrame(rafId);
          pos = 0; dir = 1; window.scrollTo(0, 0);
        }
      });
    }
  </script>
</body>
</html>
