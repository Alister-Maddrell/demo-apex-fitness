---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gym Sydney CBD | Apex Performance Studio — Free Trial" description="Sydney CBD's top-rated gym at 115 Elizabeth Street. HIIT, boxing, strength, yoga and personal training with 15 expert coaches. Try your first week free — no lock-in. Start today.">

  <!-- ═══════════════════════════════════════
       HERO — Frosted glass containers
       ═══════════════════════════════════════ -->
  <section id="hero" class="relative min-h-screen flex items-stretch overflow-hidden">
    <!-- Full-bleed background image -->
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920&h=1080&fit=crop&q=80" alt="Dark atmospheric gym interior with dramatic lighting on training equipment" class="w-full h-full object-cover" />
      <!-- Dark overlay gradient for text readability -->
      <div class="absolute inset-0 bg-gradient-to-r from-bg-primary/90 via-bg-primary/70 to-bg-primary/30"></div>
      <!-- Bottom fade -->
      <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-transparent to-bg-primary/20"></div>
    </div>

    <!-- Content layer -->
    <div id="hero-content" class="relative z-10 flex flex-col justify-center w-full px-6 sm:px-10 lg:px-16 xl:px-24 py-32 lg:py-20">
      <div class="hero-containers max-w-[600px]">

        <!-- Main card — dark frosted glass -->
        <div class="hero-glass-card hero-main-card reveal">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-[2px] bg-accent-orange"></div>
            <p class="font-display text-[0.6rem] font-700 uppercase tracking-[0.3em] text-text-muted">Sydney CBD — Est. 2014</p>
          </div>
          <h1 class="font-heading text-[clamp(3.5rem,8vw+0.5rem,7rem)] text-text-primary leading-[0.88] mb-4">
            Your Strongest<br /><span class="text-gradient-warm">Self.</span>
          </h1>
          <p class="font-body text-sm text-text-body leading-relaxed max-w-md">
            15 expert coaches. 50+ weekly classes. 500+ members seeing results at 115 Elizabeth Street.
          </p>
        </div>

        <!-- CTA card -->
        <div class="hero-glass-card hero-cta-card reveal" style="transition-delay: 150ms;">
          <div class="flex flex-row items-center gap-3">
            <a href="/contact" class="btn-primary !py-3.5 !px-8 !text-[0.7rem]">
              Start Your Free Trial
            </a>
            <a href="/classes" class="btn-secondary !py-3 !px-6 !text-[0.7rem]">
              Explore Classes
            </a>
          </div>
        </div>

        <!-- Trust banner — accent cell -->
        <div class="hero-trust-banner reveal" style="transition-delay: 280ms;">
          <span class="text-[0.65rem] font-display font-700 uppercase tracking-[0.15em] text-accent-orange">
            &#9733;&ensp;First Week Free — No Credit Card, No Lock-In
          </span>
        </div>

      </div>
    </div>

    <!-- Ambient glow -->
    <div class="absolute inset-0 glow-bg-hero pointer-events-none"></div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-6 sm:left-10 lg:left-16 flex items-center gap-4 reveal" style="transition-delay: 700ms;">
      <div class="w-[2px] h-12 bg-gradient-to-b from-accent-orange to-transparent"></div>
      <span class="text-text-muted text-[0.6rem] uppercase tracking-[0.3em] font-display font-600 -rotate-90 origin-left translate-y-1">Scroll</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       STATS BAR — Horizontal strip
       ═══════════════════════════════════════ -->
  <section class="relative bg-bg-elevated border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/5">
        <div class="py-10 lg:py-14 px-6 lg:px-10 text-center reveal stagger-1">
          <span class="font-heading text-[clamp(2.5rem,4vw,4rem)] text-text-primary leading-none block" data-count="500" data-suffix="+">0</span>
          <span class="live-dot inline-block mt-2 mb-3"></span>
          <p class="font-display text-[0.6rem] font-700 uppercase tracking-[0.25em] text-text-muted">Members</p>
        </div>
        <div class="py-10 lg:py-14 px-6 lg:px-10 text-center reveal stagger-2">
          <span class="font-heading text-[clamp(2.5rem,4vw,4rem)] text-text-primary leading-none block" data-count="15" data-suffix="">0</span>
          <p class="font-display text-[0.6rem] font-700 uppercase tracking-[0.25em] text-text-muted mt-4">Expert Coaches</p>
        </div>
        <div class="py-10 lg:py-14 px-6 lg:px-10 text-center reveal stagger-3">
          <span class="font-heading text-[clamp(2.5rem,4vw,4rem)] text-text-primary leading-none block" data-count="12" data-suffix="">0</span>
          <p class="font-display text-[0.6rem] font-700 uppercase tracking-[0.25em] text-text-muted mt-4">Years in Sydney</p>
        </div>
        <div class="py-10 lg:py-14 px-6 lg:px-10 text-center reveal stagger-4">
          <span class="font-heading text-[clamp(2.5rem,4vw,4rem)] text-text-primary leading-none block" data-count="50" data-suffix="+">0</span>
          <p class="font-display text-[0.6rem] font-700 uppercase tracking-[0.25em] text-text-muted mt-4">Weekly Classes</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CLASS TYPES — Offset grid layout
       ═══════════════════════════════════════ -->
  <section class="relative py-28 lg:py-40 bg-bg-primary overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <!-- Header with left alignment -->
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16 lg:mb-20">
        <div class="reveal">
          <h2 class="section-title">Training Programs</h2>
        </div>
        <p class="text-text-body text-sm max-w-md lg:text-right leading-relaxed reveal" style="transition-delay: 100ms;">Six ways to train, every one coached by experts. Whether you want to burn fat, build power, or clear your head — there's a class for that.</p>
      </div>

      <!-- Cards grid — 2 col with offset -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- HIIT -->
        <div class="card group overflow-hidden reveal stagger-1">
          <div class="h-52 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=800&h=600&fit=crop&q=80" alt="Athletes performing high-intensity interval training exercises in a gym" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-elevated via-transparent to-transparent opacity-90"></div>
            <span class="absolute top-4 left-4 badge-orange">High Intensity</span>
          </div>
          <div class="p-7">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-heading text-2xl text-text-primary">HIIT</h3>
              <span class="text-text-muted text-xs font-display font-600 tracking-wider uppercase">45 min</span>
            </div>
            <p class="text-sm text-text-body mb-6 leading-relaxed">Burn up to 800 calories and build explosive athleticism in 45 minutes. You'll walk out drenched, energised, and already craving the next session.</p>
            <a href="/classes" class="font-display text-sm font-700 text-accent-orange hover:text-text-primary transition-colors duration-300 uppercase tracking-[0.12em] inline-flex items-center gap-2">Learn More <span class="transition-transform duration-300 group-hover:translate-x-2">&rarr;</span></a>
          </div>
        </div>

        <!-- Strength -->
        <div class="card group overflow-hidden reveal stagger-2">
          <div class="h-52 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e?w=800&h=600&fit=crop&q=80" alt="Person performing barbell exercises for strength and conditioning training" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-elevated via-transparent to-transparent opacity-90"></div>
            <span class="absolute top-4 left-4 badge-orange">Build Power</span>
          </div>
          <div class="p-7">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-heading text-2xl text-text-primary">Strength & Conditioning</h3>
              <span class="text-text-muted text-xs font-display font-600 tracking-wider uppercase">60 min</span>
            </div>
            <p class="text-sm text-text-body mb-6 leading-relaxed">See real muscle definition and hit PRs you never thought possible. Structured programming with barbells, dumbbells, and kettlebells — scaled to your level.</p>
            <a href="/classes" class="font-display text-sm font-700 text-accent-orange hover:text-text-primary transition-colors duration-300 uppercase tracking-[0.12em] inline-flex items-center gap-2">Learn More <span class="transition-transform duration-300 group-hover:translate-x-2">&rarr;</span></a>
          </div>
        </div>

        <!-- Boxing -->
        <div class="card group overflow-hidden reveal stagger-3">
          <div class="h-52 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=800&h=600&fit=crop&q=80" alt="Boxer training with a heavy bag in a boxing gym" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-elevated via-transparent to-transparent opacity-90"></div>
            <span class="absolute top-4 left-4 badge-orange">Cardio + Skill</span>
          </div>
          <div class="p-7">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-heading text-2xl text-text-primary">Boxing</h3>
              <span class="text-text-muted text-xs font-display font-600 tracking-wider uppercase">50 min</span>
            </div>
            <p class="text-sm text-text-body mb-6 leading-relaxed">Release your stress, sharpen your reflexes, and build serious cardio. Bags, pads, and partner drills — the most addictive workout you'll ever try.</p>
            <a href="/classes" class="font-display text-sm font-700 text-accent-orange hover:text-text-primary transition-colors duration-300 uppercase tracking-[0.12em] inline-flex items-center gap-2">Learn More <span class="transition-transform duration-300 group-hover:translate-x-2">&rarr;</span></a>
          </div>
        </div>

        <!-- Yoga -->
        <div class="card group overflow-hidden reveal stagger-4">
          <div class="h-52 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&h=600&fit=crop&q=80" alt="Yoga practitioner in a serene studio performing a flexibility pose" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-elevated via-transparent to-transparent opacity-90"></div>
            <span class="absolute top-4 left-4 badge-lime">Recovery</span>
          </div>
          <div class="p-7">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-heading text-2xl text-text-primary">Yoga & Mobility</h3>
              <span class="text-text-muted text-xs font-display font-600 tracking-wider uppercase">60 min</span>
            </div>
            <p class="text-sm text-text-body mb-6 leading-relaxed">Move better, recover faster, and undo the damage of desk life. Vinyasa flow and deep stretch sessions designed for active bodies.</p>
            <a href="/classes" class="font-display text-sm font-700 text-accent-orange hover:text-text-primary transition-colors duration-300 uppercase tracking-[0.12em] inline-flex items-center gap-2">Learn More <span class="transition-transform duration-300 group-hover:translate-x-2">&rarr;</span></a>
          </div>
        </div>

        <!-- Personal Training -->
        <div class="card group overflow-hidden reveal stagger-5">
          <div class="h-52 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=800&h=600&fit=crop&q=80" alt="Personal trainer guiding a client through a workout session" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-elevated via-transparent to-transparent opacity-90"></div>
            <span class="absolute top-4 left-4 badge-orange">1-on-1</span>
          </div>
          <div class="p-7">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-heading text-2xl text-text-primary">Personal Training</h3>
              <span class="text-text-muted text-xs font-display font-600 tracking-wider uppercase">55 min</span>
            </div>
            <p class="text-sm text-text-body mb-6 leading-relaxed">Your goals, your timeline, your dedicated coach. Get a custom training and nutrition plan built around your life — and watch the results accelerate.</p>
            <a href="/classes" class="font-display text-sm font-700 text-accent-orange hover:text-text-primary transition-colors duration-300 uppercase tracking-[0.12em] inline-flex items-center gap-2">Learn More <span class="transition-transform duration-300 group-hover:translate-x-2">&rarr;</span></a>
          </div>
        </div>

        <!-- Olympic Lifting -->
        <div class="card group overflow-hidden reveal stagger-6">
          <div class="h-52 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1526506118085-60ce8714f8c5?w=800&h=600&fit=crop&q=80" alt="Athlete performing an Olympic weightlifting clean and jerk movement" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-elevated via-transparent to-transparent opacity-90"></div>
            <span class="absolute top-4 left-4 badge-orange">Technical</span>
          </div>
          <div class="p-7">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-heading text-2xl text-text-primary">Olympic Lifting</h3>
              <span class="text-text-muted text-xs font-display font-600 tracking-wider uppercase">60 min</span>
            </div>
            <p class="text-sm text-text-body mb-6 leading-relaxed">Develop explosive power and technical mastery under certified Olympic lifting coaches. From your first clean to competition-ready — every level belongs here.</p>
            <a href="/classes" class="font-display text-sm font-700 text-accent-orange hover:text-text-primary transition-colors duration-300 uppercase tracking-[0.12em] inline-flex items-center gap-2">Learn More <span class="transition-transform duration-300 group-hover:translate-x-2">&rarr;</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       MID-PAGE FREE TRIAL BANNER
       ═══════════════════════════════════════ -->
  <section class="relative py-4 bg-accent-orange overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4 py-5">
      <span class="font-heading text-[clamp(1.5rem,3vw,2.5rem)] text-black leading-none text-center sm:text-left">Your first week is <span class="font-display font-800">FREE.</span></span>
      <a href="/contact" class="btn-secondary !border-black/30 !text-black hover:!bg-black hover:!text-white hover:!border-black !text-xs whitespace-nowrap">Start Training Today</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PRICING SECTION
       ═══════════════════════════════════════ -->
  <section id="pricing" class="relative py-28 lg:py-36 bg-bg-secondary overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16 lg:mb-20">
        <div class="reveal">
          <h2 class="section-title">Your Investment</h2>
        </div>
        <p class="text-text-body text-sm max-w-md lg:text-right leading-relaxed reveal" style="transition-delay: 100ms;">Unlimited classes from less than $5 a day. No lock-in on monthly plans — stay because you want to, not because you have to.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 items-stretch">
        <!-- Casual -->
        <div class="card p-8 lg:p-10 flex flex-col reveal stagger-1" data-pricing-card>
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-white/[0.04] border border-white/8 flex items-center justify-center">
              <span class="text-lg">&#9889;</span>
            </div>
            <h3 class="font-heading text-3xl text-text-primary">Casual</h3>
          </div>
          <div class="mb-8">
            <span class="font-heading text-[clamp(3rem,4vw,4rem)] text-text-primary leading-none">$30</span>
            <span class="text-text-muted text-sm ml-2 font-display">/session</span>
          </div>
          <div class="hr-gradient mb-8"></div>
          <ul class="space-y-4 mb-10 flex-1">
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Drop into any group class, any time
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Locker and towel hire included
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Post-workout shake bar access
            </li>
          </ul>
          <a href="/contact" class="btn-secondary w-full justify-center">
            Try a Session
          </a>
        </div>

        <!-- Monthly (Featured) -->
        <div class="card-featured card glow-hover p-8 lg:p-10 flex flex-col relative reveal stagger-2" data-pricing-card>
          <span class="popular-ribbon">Most Popular</span>
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-accent-orange/10 border border-accent-orange/20 flex items-center justify-center">
              <span class="text-lg">&#128293;</span>
            </div>
            <h3 class="font-heading text-3xl text-text-primary">Monthly</h3>
          </div>
          <div class="mb-8">
            <span class="font-heading text-[clamp(3rem,4vw,4rem)] text-gradient-warm leading-none">$149</span>
            <span class="text-text-muted text-sm ml-2 font-display">/month</span>
          </div>
          <div class="hr-gradient mb-8"></div>
          <ul class="space-y-4 mb-10 flex-1">
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Everything in Casual
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Unlimited classes — train as often as you want
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Monthly body composition scan to track progress
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> 10% off personal training sessions
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Members app for booking and progress tracking
            </li>
          </ul>
          <a href="/contact" class="btn-primary w-full justify-center">
            Claim Your Free Trial
          </a>
        </div>

        <!-- Annual -->
        <div class="card p-8 lg:p-10 flex flex-col reveal stagger-3" data-pricing-card>
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-white/[0.04] border border-white/8 flex items-center justify-center">
              <span class="text-lg">&#127942;</span>
            </div>
            <h3 class="font-heading text-3xl text-text-primary">Annual</h3>
          </div>
          <div class="mb-2">
            <span class="font-heading text-[clamp(3rem,4vw,4rem)] text-text-primary leading-none">$129</span>
            <span class="text-text-muted text-sm ml-2 font-display">/month</span>
          </div>
          <p class="text-xs text-text-muted mb-8 font-display">Billed $1,548 yearly · <span class="text-accent-amber font-700">You save $240</span></p>
          <div class="hr-gradient mb-8"></div>
          <ul class="space-y-4 mb-10 flex-1">
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Everything in Monthly
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> 2 personal training sessions per month included
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Priority class booking — never miss a session
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Welcome merchandise pack
            </li>
            <li class="flex items-start gap-3 text-sm text-text-body">
              <span class="text-accent-orange mt-0.5 flex-shrink-0 text-xs">&#10003;</span> Exclusive member events and workshops
            </li>
          </ul>
          <a href="/contact" class="btn-secondary w-full justify-center">
            Lock In Your Savings
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section Transition -->
  <div class="section-transition">
    <div class="absolute inset-0 speed-lines"></div>
  </div>

  <!-- ═══════════════════════════════════════
       TRANSFORMATIONS — Before/After
       ═══════════════════════════════════════ -->
  <section class="relative py-28 lg:py-40 bg-bg-primary overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-16 lg:mb-20 reveal">
        <h2 class="section-title">Real Results, Real People</h2>
        <p class="section-subtitle mt-8">These are everyday Sydneysiders who showed up and put in the work. Drag the slider to see their transformations.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <!-- Transformation 1 -->
        <div class="card overflow-hidden reveal stagger-1">
          <div class="ba-slider relative h-72" data-before-after>
            <img src="https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=600&h=450&fit=crop&q=80" alt="Jake's fitness transformation after photo showing muscular physique" class="ba-after" />
            <div class="ba-before" style="width: 50%;">
              <img src="https://images.unsplash.com/photo-1507398941214-572c25f4b1dc?w=600&h=450&fit=crop&q=80" alt="Jake's fitness transformation before photo" />
            </div>
            <div class="ba-handle" style="left: 50%;"></div>
            <span class="ba-label left-3">Before</span>
            <span class="ba-label right-3">After</span>
          </div>
          <div class="p-7">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-heading text-xl text-text-primary">Jake M.</h3>
              <span class="badge-orange">12 Weeks</span>
            </div>
            <div class="star-rating mb-3">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="text-sm text-text-body italic leading-relaxed">"I lost 15kg and gained confidence I never thought I'd have. The coaches at Apex changed my life."</p>
          </div>
        </div>

        <!-- Transformation 2 -->
        <div class="card overflow-hidden reveal stagger-2">
          <div class="ba-slider relative h-72" data-before-after>
