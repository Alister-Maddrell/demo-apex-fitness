---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Classes & Coaching — Apex Performance Studio">

  <!-- ═══════════════════════════════════════
       PAGE HEADER — Layered hero
       ═══════════════════════════════════════ -->
  <section class="relative pt-36 pb-24 bg-bg-primary overflow-hidden">
    <!-- Background layers -->
    <div class="absolute inset-0 bg-gradient-to-b from-accent-orange/[0.03] to-transparent"></div>
    <div class="absolute inset-0 dot-grid"></div>
    <div class="absolute top-0 right-[20%] w-[400px] h-[300px] bg-accent-orange/[0.02] blur-[100px] rounded-full pointer-events-none"></div>
    <!-- Decorative elements -->
    <div class="absolute top-1/3 left-8 w-16 h-16 border border-accent-orange/8 rotate-45 hidden lg:block rounded-sm"></div>
    <div class="absolute bottom-1/4 right-12 h-24 deco-line-v hidden lg:block"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-4 mb-4 reveal">
        <span class="w-8 h-px bg-accent-orange/40 hidden sm:block"></span>
        <p class="section-overline !mb-0">Expert-Led Training</p>
        <span class="w-8 h-px bg-accent-orange/40 hidden sm:block"></span>
      </div>
      <h1 class="font-heading text-[clamp(3rem,5vw+1rem,6rem)] text-text-primary leading-[0.92] mb-6 reveal" style="transition-delay: 100ms;">
        Classes & <span class="text-gradient-warm">Coaching</span>
      </h1>
      <div class="section-divider mx-auto reveal" style="transition-delay: 200ms;"></div>
      <p class="section-subtitle mt-8 reveal" style="transition-delay: 300ms;">From high-intensity group sessions to personalised one-on-one training. Find what drives you.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       WEEKLY TIMETABLE
       ═══════════════════════════════════════ -->
  <section class="relative py-24 bg-bg-secondary angle-top overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[300px] bg-accent-orange/[0.015] blur-[100px] rounded-full"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 relative">
      <div class="text-center mb-14 reveal">
        <p class="section-overline">Timetable</p>
        <h2 class="section-title">Weekly Schedule</h2>
        <div class="section-divider mx-auto"></div>
        <p class="section-subtitle mt-6">Plan your week with our structured class timetable. Every session is coach-led.</p>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap gap-4 lg:gap-6 justify-center mb-10 reveal">
        <div class="flex items-center gap-2 glass-card px-3 py-1.5"><span class="w-2.5 h-2.5 rounded-full bg-[#FF6B2C]"></span><span class="text-xs text-text-body font-display font-medium">HIIT</span></div>
        <div class="flex items-center gap-2 glass-card px-3 py-1.5"><span class="w-2.5 h-2.5 rounded-full bg-[#3B82F6]"></span><span class="text-xs text-text-body font-display font-medium">Strength</span></div>
        <div class="flex items-center gap-2 glass-card px-3 py-1.5"><span class="w-2.5 h-2.5 rounded-full bg-[#EF4444]"></span><span class="text-xs text-text-body font-display font-medium">Boxing</span></div>
        <div class="flex items-center gap-2 glass-card px-3 py-1.5"><span class="w-2.5 h-2.5 rounded-full bg-[#AAFF00]"></span><span class="text-xs text-text-body font-display font-medium">Yoga</span></div>
        <div class="flex items-center gap-2 glass-card px-3 py-1.5"><span class="w-2.5 h-2.5 rounded-full bg-[#A855F7]"></span><span class="text-xs text-text-body font-display font-medium">Olympic Lifting</span></div>
      </div>

      <!-- Desktop Timetable -->
      <div class="overflow-x-auto hidden md:block reveal card p-6" data-timetable>
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr>
              <th class="p-3 text-left font-heading text-text-muted text-lg">Time</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Mon</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Tue</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Wed</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Thu</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Fri</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Sat</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Sun</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-white/5">
              <td class="p-3 font-display text-text-muted font-semibold text-xs tracking-wider">6:00 AM</td>
              <td class="p-2"><div class="class-hiit rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">HIIT</span></div></td>
              <td class="p-2"><div class="class-strength rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Strength</span></div></td>
              <td class="p-2"><div class="class-boxing rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Boxing</span></div></td>
              <td class="p-2"><div class="class-hiit rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">HIIT</span></div></td>
              <td class="p-2"><div class="class-strength rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Strength</span></div></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="p-3 font-display text-text-muted font-semibold text-xs tracking-wider">7:00 AM</td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"><div class="class-hiit rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">HIIT</span></div></td>
              <td class="p-2"></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="p-3 font-display text-text-muted font-semibold text-xs tracking-wider">8:00 AM</td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"><div class="class-yoga rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Yoga</span></div></td>
