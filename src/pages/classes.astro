        </div>
        <div class="reveal stagger-3">
          <h3 class="font-heading text-xl text-text-primary mb-3 flex items-center gap-3"><span class="w-6 h-px bg-accent-orange/40"></span>Wednesday</h3>
          <div class="space-y-2">
            <div class="class-boxing rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">Boxing</span><span class="text-text-body text-xs font-display">6:00 AM</span></div>
