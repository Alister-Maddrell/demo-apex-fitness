  <section class="relative py-28 lg:py-36 bg-bg-primary overflow-hidden">
    <div class="absolute top-0 left-[10%] w-[500px] h-[400px] bg-accent-orange/[0.015] blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-0 right-[15%] w-[400px] h-[300px] bg-accent-amber/[0.01] blur-[100px] rounded-full pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-20 reveal">
        <p class="section-overline">Our Team</p>
        <h2 class="section-title">Meet Your Coaches</h2>
        <div class="section-divider mx-auto"></div>
        <p class="section-subtitle mt-6">Six world-class coaches. Decades of combined experience. One shared mission: your transformation.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Marcus Reid -->
        <div class="card group overflow-hidden reveal stagger-1">
          <div class="h-80 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1567013127542-490d757e51fc?w=400&h=500&fit=crop&q=80" alt="Marcus Reid, Head Coach specialising in Strength and Conditioning" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 trainer-overlay"></div>
            <span class="absolute top-4 right-4 badge-orange">Head Coach</span>
          </div>
          <div class="p-8">
            <h3 class="font-heading text-2xl text-text-primary mb-1">Marcus Reid</h3>
            <p class="text-accent-orange font-display text-sm font-semibold mb-1.5">Strength & Conditioning</p>
            <p class="text-text-muted text-xs font-display mb-4 flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-orange/60"></span>14 Years Experience
            </p>
            <p class="text-text-body text-sm leading-relaxed">"Former professional rugby player. Believes everyone has an athlete inside them."</p>
          </div>
        </div>

        <!-- Sophie Chen -->
        <div class="card group overflow-hidden reveal stagger-2">
          <div class="h-80 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1548690312-e3b507d8c110?w=400&h=500&fit=crop&q=80" alt="Sophie Chen, HIIT and Boxing coach in action" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 trainer-overlay"></div>
          </div>
          <div class="p-8">
            <h3 class="font-heading text-2xl text-text-primary mb-1">Sophie Chen</h3>
            <p class="text-accent-orange font-display text-sm font-semibold mb-1.5">HIIT & Boxing</p>
            <p class="text-text-muted text-xs font-display mb-4 flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-orange/60"></span>8 Years Experience
            </p>
            <p class="text-text-body text-sm leading-relaxed">"Certified in sports science and boxing coaching. Brings the energy every single session."</p>
          </div>
        </div>

        <!-- James Okafor -->
        <div class="card group overflow-hidden reveal stagger-3">
          <div class="h-80 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1583468982228-19f19164aee2?w=400&h=500&fit=crop&q=80" alt="James Okafor, Olympic Lifting coach demonstrating technique" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 trainer-overlay"></div>
          </div>
