              <td class="p-2"></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="p-3 font-display text-text-muted font-semibold text-xs tracking-wider">12:00 PM</td>
              <td class="p-2"><div class="class-boxing rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Boxing</span></div></td>
              <td class="p-2"><div class="class-hiit rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">HIIT</span></div></td>
              <td class="p-2"><div class="class-yoga rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Yoga</span></div></td>
              <td class="p-2"><div class="class-strength rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Strength</span></div></td>
              <td class="p-2"><div class="class-hiit rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">HIIT</span></div></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="p-3 font-display text-text-muted font-semibold text-xs tracking-wider">5:30 PM</td>
              <td class="p-2"><div class="class-strength rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Strength</span></div></td>
              <td class="p-2"><div class="class-boxing rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Boxing</span></div></td>
              <td class="p-2"><div class="class-hiit rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">HIIT</span></div></td>
              <td class="p-2"><div class="class-olympic rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Olympic</span></div></td>
              <td class="p-2"><div class="class-boxing rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Boxing</span></div></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="p-3 font-display text-text-muted font-semibold text-xs tracking-wider">6:30 PM</td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"><div class="class-yoga rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Yoga</span></div></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
            </tr>
            <tr class="border-t border-white/5">
