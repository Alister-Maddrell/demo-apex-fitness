              <td class="p-2"></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="p-3 font-display text-text-muted font-semibold text-xs tracking-wider">10:00 AM</td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"><div class="class-boxing rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Boxing</span></div></td>
