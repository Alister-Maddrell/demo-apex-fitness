---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Classes & Coaching — Apex Performance Studio">

  <!-- Page Header -->
  <section class="relative pt-36 pb-20 bg-bg-primary overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-accent-orange/3 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-overline reveal">Expert-Led Training</p>
      <h1 class="font-heading text-[clamp(3rem,5vw+1rem,5.5rem)] text-text-primary leading-[0.95] mb-6 reveal" style="transition-delay: 100ms;">Classes & Coaching</h1>
      <div class="section-divider mx-auto reveal" style="transition-delay: 200ms;"></div>
      <p class="font-body text-lg text-text-body max-w-2xl mx-auto mt-6 reveal" style="transition-delay: 300ms;">From high-intensity group sessions to personalised one-on-one training. Find what drives you.</p>
    </div>
  </section>

  <!-- Weekly Timetable -->
  <section class="py-20 bg-bg-secondary angle-top">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <div class="text-center mb-12 reveal">
        <p class="section-overline">Timetable</p>
        <h2 class="section-title">Weekly Schedule</h2>
        <div class="section-divider mx-auto"></div>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap gap-4 lg:gap-6 justify-center mb-10 reveal">
        <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#FF6B2C]"></span><span class="text-xs text-text-body font-body font-medium">HIIT</span></div>
        <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#3B82F6]"></span><span class="text-xs text-text-body font-body font-medium">Strength</span></div>
        <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#EF4444]"></span><span class="text-xs text-text-body font-body font-medium">Boxing</span></div>
        <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#AAFF00]"></span><span class="text-xs text-text-body font-body font-medium">Yoga</span></div>
        <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#A855F7]"></span><span class="text-xs text-text-body font-body font-medium">Olympic Lifting</span></div>
      </div>

      <!-- Desktop Timetable -->
      <div class="overflow-x-auto hidden md:block reveal" data-timetable>
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr>
              <th class="p-3 text-left font-heading text-text-muted text-lg">Time</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Mon</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Tue</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Wed</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Thu</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Fri</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Sat</th>
              <th class="p-3 text-center font-heading text-text-primary text-lg">Sun</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-white/5">
              <td class="p-3 font-body text-text-muted font-semibold">6:00 AM</td>
              <td class="p-2"><div class="class-hiit rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-body font-semibold">HIIT</span></div></td>
              <td class="p-2"><div class="class-strength rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-body font-semibold">Strength</span></div></td>
              <td class="p-2"><div class="class-boxing rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-body font-semibold">Boxing</span></div></td>
