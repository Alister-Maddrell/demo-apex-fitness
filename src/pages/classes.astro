      </div>

      <!-- Mobile Timetable -->
      <div class="md:hidden space-y-6" data-timetable>
        <div class="reveal stagger-1">
          <h3 class="font-heading text-xl text-text-primary mb-3">Monday</h3>
          <div class="space-y-2">
            <div class="class-hiit rounded-lg p-3.5 flex justify-between items-center"><span class="text-text-primary text-sm font-body font-semibold">HIIT</span><span class="text-text-body text-xs font-body">6:00 AM</span></div>
            <div class="class-boxing rounded-lg p-3.5 flex justify-between items-center"><span class="text-text-primary text-sm font-body font-semibold">Boxing</span><span class="text-text-body text-xs font-body">12:00 PM</span></div>
            <div class="class-strength rounded-lg p-3.5 flex justify-between items-center"><span class="text-text-primary text-sm font-body font-semibold">Strength</span><span class="text-text-body text-xs font-body">5:30 PM</span></div>
