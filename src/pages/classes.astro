              <td class="p-2"><div class="class-olympic rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Olympic</span></div></td>
              <td class="p-2"><div class="class-strength rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Strength</span></div></td>
              <td class="p-2"><div class="class-boxing rounded-lg p-2.5 text-center"><span class="text-text-primary text-xs font-display font-semibold">Boxing</span></div></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
              <td class="p-2"></td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile Timetable -->
      <div class="md:hidden space-y-6" data-timetable>
        <div class="reveal stagger-1">
          <h3 class="font-heading text-xl text-text-primary mb-3 flex items-center gap-3"><span class="w-6 h-px bg-accent-orange/40"></span>Monday</h3>
          <div class="space-y-2">
            <div class="class-hiit rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">HIIT</span><span class="text-text-body text-xs font-display">6:00 AM</span></div>
            <div class="class-boxing rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">Boxing</span><span class="text-text-body text-xs font-display">12:00 PM</span></div>
            <div class="class-strength rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">Strength</span><span class="text-text-body text-xs font-display">5:30 PM</span></div>
            <div class="class-yoga rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">Yoga</span><span class="text-text-body text-xs font-display">7:00 PM</span></div>
          </div>
        </div>
        <div class="reveal stagger-2">
          <h3 class="font-heading text-xl text-text-primary mb-3 flex items-center gap-3"><span class="w-6 h-px bg-accent-orange/40"></span>Tuesday</h3>
          <div class="space-y-2">
            <div class="class-strength rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">Strength</span><span class="text-text-body text-xs font-display">6:00 AM</span></div>
            <div class="class-hiit rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">HIIT</span><span class="text-text-body text-xs font-display">12:00 PM</span></div>
            <div class="class-boxing rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">Boxing</span><span class="text-text-body text-xs font-display">5:30 PM</span></div>
            <div class="class-olympic rounded-xl p-4 flex justify-between items-center"><span class="text-text-primary text-sm font-display font-semibold">Olympic Lifting</span><span class="text-text-body text-xs font-display">7:00 PM</span></div>
